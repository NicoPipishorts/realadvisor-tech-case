{
  "name": "@realadvisor/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "node scripts/run-prisma.mjs generate --schema prisma/schema.prisma",
    "prisma:migrate": "node scripts/run-prisma.mjs migrate dev --schema prisma/schema.prisma",
    "prisma:seed": "node --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "graphql": "^16.9.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  }
}
